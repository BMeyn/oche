# Copy to `.env` and fill in real values before running `docker compose up`.
#   cp .env.example .env

# ─── Postgres ────────────────────────────────────────────────────
# Used by both the `db` service and the app's DATABASE_URL.
POSTGRES_USER=oche
POSTGRES_DB=oche
# REQUIRED — pick a strong password (e.g. `openssl rand -base64 24`).
POSTGRES_PASSWORD=change-me-please

# ─── Auth ────────────────────────────────────────────────────────
# 32-byte random secret for session signing (generate: openssl rand -hex 32)
AUTH_SECRET=change-me-please
# Public URL of the app — used to build the magic-link in emails
APP_URL=https://oche.cloud
# Resend API key (https://resend.com — free tier: 100 emails/day)
RESEND_API_KEY=re_change-me
# Verified sending domain in Resend (may differ from APP_URL, e.g. contact.oche.cloud)
RESEND_FROM_DOMAIN=contact.oche.cloud

# ─── Caddy ───────────────────────────────────────────────────────
# Leave as `:80` to serve plain HTTP on port 80 (good for IP-only setups).
# Set to a bare domain (no port suffix) and Caddy will obtain a
# Let's Encrypt cert automatically — ports 80 + 443 must be reachable.
# DOMAIN=:80          ← HTTP-only (IP-only / no cert)
# DOMAIN=oche.cloud   ← HTTPS via Let's Encrypt
DOMAIN=:80
